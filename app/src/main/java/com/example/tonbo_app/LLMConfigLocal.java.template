    public static final String OSS_ACCESS_KEY_ID = "YOUR_OSS_ACCESS_KEY_ID_HERE";
    public static final String OSS_ACCESS_KEY_SECRET = "YOUR_OSS_ACCESS_KEY_SECRET_HERE";
    public static final String OSS_BUCKET_NAME = "YOUR_OSS_BUCKET_NAME_HERE";
    public static final String OSS_ENDPOINT = "YOUR_OSS_ENDPOINT_HERE"; // 例如: oss-cn-hangzhou.aliyuncs.com
    public static final String OSS_REGION = "YOUR_OSS_REGION_HERE"; // 例如: cn-hangzhou
}

