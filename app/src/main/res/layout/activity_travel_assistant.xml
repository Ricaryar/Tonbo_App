<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 頂部標題區域 -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 返回按鈕 -->
        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/button_square_background"
            android:backgroundTint="@color/menu_blue"
            android:src="@drawable/ic_back_arrow_white"
            android:scaleType="center"
            android:contentDescription="@string/back_button_desc"
            android:layout_marginEnd="16dp" />

        <!-- 頁面標題 -->
        <TextView
            android:id="@+id/page_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/travel_assistant_title"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:contentDescription="@string/travel_assistant_title_desc"
            android:minHeight="48dp" />

    </LinearLayout>

    <!-- 語音狀態提示區域 -->
    <LinearLayout
        android:id="@+id/voice_status_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_marginHorizontal="20dp"
        android:background="@drawable/settings_section_background"
        android:contentDescription="@string/voice_status_desc"
        app:layout_constraintTop_toBottomOf="@id/header_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 語音狀態標題 -->
        <TextView
            android:id="@+id/voice_status_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/voice_status_title"
            android:textColor="#4FC3F7"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:paddingBottom="8dp"
            android:contentDescription="@string/voice_status_title_desc" />

        <!-- 語音狀態內容 -->
        <TextView
            android:id="@+id/voice_status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/voice_status_ready"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textAlignment="center"
            android:minHeight="60dp"
            android:gravity="center"
            android:padding="12dp"
            android:background="#1A1A1A"
            android:contentDescription="@string/voice_status_text_desc" />

    </LinearLayout>

    <!-- 功能按鈕區域 -->
    <LinearLayout
        android:id="@+id/control_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/voice_status_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 開始出行 -->
        <Button
            android:id="@+id/start_travel_voice_button"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="@string/start_travel_voice"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/button_square_background"
            android:backgroundTint="@color/menu_blue"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp"
            android:contentDescription="@string/start_travel_voice_desc" />

        <!-- 聯繫志願者 -->
        <Button
            android:id="@+id/emergency_button"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="@string/contact_volunteer"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/button_square_background"
            android:backgroundTint="@color/emergency_red"
            android:textColor="@color/white"
            android:contentDescription="@string/contact_volunteer_desc" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
