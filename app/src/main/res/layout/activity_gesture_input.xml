<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 頂部標題區域 -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 頁面標題 -->
        <TextView
            android:id="@+id/page_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="手勢登入"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:contentDescription="手勢登入頁面標題"
            android:layout_marginBottom="16dp" />

        <!-- 說明文字 -->
        <TextView
            android:id="@+id/instruction_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="畫❌進入主頁，或繪製已保存的手勢進入對應功能"
            android:textColor="#4FC3F7"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- 提示文字 -->
        <TextView
            android:id="@+id/hint_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="請在下方區域繪製手勢"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:gravity="center" />

    </LinearLayout>

    <!-- 手勢書寫區域 -->
    <FrameLayout
        android:id="@+id/gesture_draw_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/gesture_draw_background"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/header_layout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 手勢繪畫視圖 -->
        <com.example.tonbo_app.GestureDrawView
            android:id="@+id/gesture_draw_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gesture_draw_background" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

