<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 頂部標題區域 -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/button_square_background"
            android:backgroundTint="@color/menu_blue"
            android:src="@drawable/ic_back_arrow_white"
            android:scaleType="center"
            android:contentDescription="@string/back_button_desc"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/page_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/start_travel_voice"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:contentDescription="@string/start_travel_voice_desc"
            android:minHeight="48dp" />
    </LinearLayout>

    <!-- 提示與狀態區域 -->
    <LinearLayout
        android:id="@+id/prompt_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_marginHorizontal="20dp"
        android:background="@drawable/settings_section_background"
        app:layout_constraintTop_toBottomOf="@id/header_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/prompt_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/say_destination_prompt"
            android:textColor="#4FC3F7"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:paddingBottom="12dp"
            android:contentDescription="@string/say_destination_prompt_desc" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/voice_status_ready"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textAlignment="center"
            android:minHeight="40dp"
            android:gravity="center"
            android:padding="8dp"
            android:background="#1A1A1A"
            android:contentDescription="@string/voice_status_text_desc" />

        <!-- 語音識別結果（可編輯） -->
        <TextView
            android:id="@+id/recognition_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/recognition_result_label"
            android:textColor="#4FC3F7"
            android:textSize="14sp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:visibility="visible" />
        <EditText
            android:id="@+id/recognition_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:padding="12dp"
            android:background="#1A1A1A"
            android:textColor="#FFFFFF"
            android:hint="@string/recognition_result_hint"
            android:inputType="text"
            android:maxLines="3"
            android:visibility="visible"
            android:contentDescription="@string/recognition_result_hint" />
    </LinearLayout>

    <!-- 多個 POI 時由程式顯示最多三個候選 +「使用上方文字」 -->
    <LinearLayout
        android:id="@+id/poi_choice_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="12dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/settings_section_background"
        app:layout_constraintTop_toBottomOf="@id/prompt_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/poi_choice_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#4FC3F7"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="8dp"
            android:text="請選擇目的地" />

        <Button
            android:id="@+id/btn_poi_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:visibility="gone"
            android:textSize="15sp"
            android:background="@drawable/button_square_background"
            android:backgroundTint="@color/menu_blue"
            android:textColor="@color/white"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btn_poi_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:visibility="gone"
            android:textSize="15sp"
            android:background="@drawable/button_square_background"
            android:backgroundTint="@color/menu_blue"
            android:textColor="@color/white"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btn_poi_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:visibility="gone"
            android:textSize="15sp"
            android:background="@drawable/button_square_background"
            android:backgroundTint="@color/menu_blue"
            android:textColor="@color/white"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btn_poi_use_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:visibility="gone"
            android:textSize="15sp"
            android:text="使用上方輸入文字導航"
            android:background="@drawable/button_square_background"
            android:backgroundTint="@color/button_green"
            android:textColor="@color/white" />
    </LinearLayout>

    <!-- 確認出發按鈕 -->
    <Button
        android:id="@+id/confirm_button"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="确认出发"
        android:textSize="16sp"
        android:visibility="visible"
        android:background="@drawable/button_square_background"
        android:backgroundTint="@color/button_green"
        android:textColor="@color/white"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/poi_choice_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 麥克風按鈕 -->
    <Button
        android:id="@+id/mic_button"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:text="🎤"
        android:textSize="72sp"
        android:background="@drawable/voice_button_background"
        android:backgroundTint="@null"
        android:contentDescription="麥克風"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/confirm_button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
