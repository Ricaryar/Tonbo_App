@startuml Main_Activity_Sequence
!theme plain
skinparam backgroundColor #FFFFFF

actor User
participant "MainActivity" as Main
participant "Feature Activities" as Feature

User -> Main: Launch Main Screen
activate Main

Main -> Main: onCreate()
Main -> Main: setupFunctionList()
Main --> User: Display Home Functions

alt User Clicks Feature Button
    User -> Main: Click Feature (e.g., Environment)
    Main -> Feature: startActivity(FeatureActivity)
    activate Feature
    Feature --> User: Open Feature Screen
    deactivate Feature
else User Long Presses Emergency Button
    User -> Main: Long Press (3 seconds)
    Main -> Main: triggerEmergencyCall()
    Main --> User: Dial 999
else User Clicks Language Switch
    User -> Main: Click Language Button
    Main -> Main: toggleLanguage()
    Main --> User: Update UI Language
end

deactivate Main

@enduml
