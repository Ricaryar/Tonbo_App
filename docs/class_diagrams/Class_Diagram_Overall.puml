' Manager Classes (Singleton)
class TTSManager {
    {static} + getInstance(Context): TTSManager
    + speak(String, String, boolean): void
    + setLanguage(String): void
    + setSpeechRate(float): void
    --
    File: TTSManager.java
    Singleton Pattern
    Cantonese/Mandarin/English
}

class VibrationManager {
    {static} + getInstance(Context): VibrationManager
    + vibrateClick(): void
    + vibrateEmergencyPattern(): void
    --
    File: VibrationManager.java
    Singleton Pattern
}

class LocaleManager {
    {static} + getInstance(Context): LocaleManager
    + switchLanguage(String): void
    + getCurrentLanguage(): String
    --
    File: LocaleManager.java
    Singleton Pattern
}

class UserManager {
    {static} + getInstance(Context): UserManager
    + isUserLoggedIn(): boolean
    + setUserLoggedIn(boolean): void
    --
    File: UserManager.java
    Singleton Pattern
}

class EmergencyManager {
    {static} + getInstance(Context): EmergencyManager
    + triggerEmergencyAlert(): void
    - callEmergencyService(): void
    --
    File: EmergencyManager.java
    Singleton Pattern
    Direct 999 dialing
}

class ConversationManager {
    {static} + getInstance(): ConversationManager
    + addMessage(String, String): void
