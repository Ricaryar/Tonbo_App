@startuml Overall_Class_Diagram
!theme plain
skinparam backgroundColor #FFFFFF
skinparam class {
    BackgroundColor #E1F5FE
    BorderColor #01579B
}

' Base Classes
abstract class BaseAccessibleActivity {
    # TTSManager ttsManager
    # VibrationManager vibrationManager
    # LocaleManager localeManager
    # String currentLanguage
    + onCreate(Bundle): void
    + announceInfo(String): void
    + announceError(String): void
    + handleVoiceCommand(): void
    + goToHome(): void
    --
    File: BaseAccessibleActivity.java
    Template Method Pattern
}

' Activity Classes
class MainActivity extends BaseAccessibleActivity {
    - EmergencyManager emergencyManager
    - ViewPager2 viewPager
    + onCreate(Bundle): void
    + toggleLanguage(): void
    - triggerEmergencyCall(): void
    --
    File: MainActivity.java
    Emergency: 3s long press
}

class RealAIDetectionActivity extends BaseAccessibleActivity {
