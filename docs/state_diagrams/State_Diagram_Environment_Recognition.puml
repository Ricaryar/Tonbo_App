@startuml Environment_Recognition_States
!theme plain
skinparam backgroundColor #FFFFFF
skinparam state {
    BackgroundColor #E1F5FE
    BorderColor #01579B
}

[*] --> Idle : App Started

Idle --> Initializing : User Opens Feature
Initializing --> CameraStarting : Initialize Complete
CameraStarting --> Detecting : Camera Ready
Detecting --> Processing : Frame Received
Processing --> Announcing : Results Ready
Announcing --> Detecting : Continue Detection
Detecting --> Stopped : User Stops
Stopped --> [*] : Activity Destroyed

Processing --> Detecting : Skip Frame\n(Every 3 frames)


@enduml
